# ZapZone Mobile — environment variables
# Copy to `.env` and fill in. All EXPO_PUBLIC_* vars are inlined at build time.

# Backend API base URL (must end without a trailing slash; "/api" is appended if missing).
# Defaults to the production backend when unset.
EXPO_PUBLIC_API_BASE_URL=https://zapzone-backend-yt1lm2w5.on-forge.com/api

# Sentry DSN for crash/error reporting (optional — leave blank to disable).
EXPO_PUBLIC_SENTRY_DSN=
